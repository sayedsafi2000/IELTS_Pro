DATABASE_URL=postgresql://user:password@localhost:5432/ielts_db
JWT_ACCESS_SECRET=change_me_in_prod
JWT_REFRESH_SECRET=change_me_in_prod
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
PORT=5000
CLIENT_URL=http://localhost:5173

# SMTP — leave SMTP_USER as default to stub emails to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ieltsplatform.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@ieltsplatform.com

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INTEGRATION_ENC_KEY=

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:5000/api/integrations/google/callback

# Zoom OAuth
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_REDIRECT=http://localhost:5000/api/integrations/zoom/callback
