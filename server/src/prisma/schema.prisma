// ── FILE: server/src/prisma/schema.prisma ──
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(STUDENT)
  phone        String?
  avatar       String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     TestSession[]
  enrollments  Enrollment[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  examinerLiveSessions LiveSpeakingSession[] @relation("ExaminerLiveSessions")
  integrations ExaminerIntegration[]
}

enum Role {
  STUDENT
  ADMIN
  EXAMINER
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Test {
  id           String    @id @default(uuid())
  title        String
  description  String?
  type         TestType  @default(FULL)
  isPublished  Boolean   @default(false)
  duration     Int       @default(165)
  price        Float     @default(0)
  bkashNumber  String?
  bankAccount  String?
  bankName     String?
  isPaid       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  modules      Module[]
  enrollments  Enrollment[]
  sessions     TestSession[]
}

enum TestType {
  FULL
  LISTENING_ONLY
  READING_ONLY
  WRITING_ONLY
  SPEAKING_ONLY
}

model Module {
  id                  String      @id @default(uuid())
  testId              String
  test                Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  type                ModuleType
  title               String
  instructions        String?
  durationMins        Int
  orderIndex          Int
  audioUrl            String?
  cloudinaryPublicId  String?
  speakingMode        SpeakingMode @default(RECORDED)
  questions           Question[]
  mediaFiles          MediaFile[]
  sessions            ModuleSession[]

  @@unique([testId, type])
}

enum ModuleType {
  LISTENING
  READING
  WRITING
  SPEAKING
}

enum SpeakingMode {
  RECORDED
  LIVE
}

model Question {
  id             String        @id @default(uuid())
  moduleId       String
  module         Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type           QuestionType
  questionText   String
  instructions   String?
  imageUrl       String?
  imagePublicId  String?
  options        Json?
  correctAnswer  Json?
  acceptedAnswers Json?
  marks          Int           @default(1)
  orderIndex     Int
  section        Int           @default(1)
  answers        Answer[]
  speakingResponses SpeakingResponse[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NG
  FILL_BLANK
  SHORT_ANSWER
  MATCHING
  MATCHING_HEADINGS
  SENTENCE_COMPLETION
  DIAGRAM_LABELING
  FORM_COMPLETION
  NOTE_COMPLETION
  TABLE_COMPLETION
  FLOW_CHART_COMPLETION
  SUMMARY_COMPLETION
  MAP_LABELING
  PLAN_LABELING
  WRITING_TASK1
  WRITING_TASK2
  SPEAKING_PART1
  SPEAKING_PART2
  SPEAKING_PART3
}

model MediaFile {
  id         String   @id @default(uuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileType   FileType
  purpose    String?
  orderIndex Int     @default(0)
  createdAt  DateTime @default(now())
}

enum FileType {
  AUDIO
  IMAGE
  PDF
}

model Enrollment {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId          String
  test            Test              @relation(fields: [testId], references: [id], onDelete: Cascade)
  status          EnrollmentStatus  @default(PENDING)
  trxId           String?
  paymentMethod   PaymentMethod?
  amountPaid      Float?
  paidAt          DateTime?
  assignedAt      DateTime          @default(now())
  dueDate         DateTime?
  assignedBy      String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentMethod {
  BKASH
  NAGAD
  BANK
  MANUAL
}

model TestSession {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId         String
  test           Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  mode           SessionMode     @default(EXAM)
  status         SessionStatus   @default(IN_PROGRESS)
  currentModule  Int             @default(0)
  startedAt      DateTime        @default(now())
  submittedAt    DateTime?
  tabSwitchCount Int             @default(0)
  modulesSessions ModuleSession[]
  result         Result?
}

enum SessionMode {
  EXAM
  PRACTICE
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  ABANDONED
}

model ModuleSession {
  id                 String               @id @default(uuid())
  sessionId          String
  session            TestSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moduleId           String
  module             Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status             ModuleSessionStatus  @default(NOT_STARTED)
  startedAt          DateTime?
  submittedAt        DateTime?
  timeLeft           Int?
  answers            Answer[]
  writingSubmissions WritingSubmission[]
  speakingSubmission SpeakingSubmission?
  liveSpeakingSession LiveSpeakingSession?
}

enum ModuleSessionStatus {
  NOT_STARTED
  IN_PROGRESS
  AWAITING_LIVE
  SUBMITTED
}

model Answer {
  id              String        @id @default(uuid())
  moduleSessionId String
  moduleSession   ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswer   String?
  isCorrect       Boolean?
  marksAwarded    Int           @default(0)
  isFlagged       Boolean       @default(false)
  savedAt         DateTime      @default(now())
}

model WritingSubmission {
  id                  String        @id @default(uuid())
  moduleSessionId     String
  moduleSession       ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  taskNumber          Int
  content             String        @db.Text
  wordCount           Int
  taskAchievement     Float?
  coherenceCohesion   Float?
  lexicalResource     Float?
  grammaticalRange    Float?
  bandScore           Float?
  feedback            String?       @db.Text
  evaluatedBy         String?
  evaluatedAt         DateTime?
}

model SpeakingSubmission {
  id                 String        @id @default(uuid())
  moduleSessionId    String        @unique
  moduleSession      ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  audioUrl           String?
  audioPublicId      String?
  duration           Int?
  fluencyCoherence   Float?
  lexicalResource    Float?
  grammaticalRange  Float?
  pronunciation      Float?
  bandScore          Float?
  feedback           String?       @db.Text
  evaluatedBy        String?
  evaluatedAt        DateTime?
  responses          SpeakingResponse[]
}

model SpeakingResponse {
  id            String              @id @default(uuid())
  submissionId  String
  submission    SpeakingSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId    String
  question      Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  audioUrl      String
  audioPublicId String?
  duration      Int?
  recordedAt    DateTime            @default(now())

  @@unique([submissionId, questionId])
}

model LiveSpeakingSession {
  id                 String   @id @default(uuid())
  moduleSessionId    String   @unique
  moduleSession      ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  examinerId         String?
  examiner           User?    @relation("ExaminerLiveSessions", fields: [examinerId], references: [id], onDelete: SetNull)
  scheduledAt        DateTime
  durationMins       Int      @default(15)
  meetingUrl         String?
  meetingProvider    MeetingProvider @default(GOOGLE_MEET)
  meetingExternalId  String?
  recordingUrl       String?
  recordingPublicId  String?
  status             LiveSessionStatus @default(REQUESTED)
  studentPreferredAt DateTime?
  notes              String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([examinerId, scheduledAt])
  @@index([status])
}

enum MeetingProvider {
  GOOGLE_MEET
  ZOOM
  OTHER
}

enum LiveSessionStatus {
  REQUESTED
  SCHEDULED
  RESCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model ExaminerIntegration {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             MeetingProvider
  accessToken          String   @db.Text
  refreshToken         String?  @db.Text
  expiresAt            DateTime?
  scope                String?  @db.Text
  externalAccountEmail String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, provider])
}

model Result {
  id           String      @id @default(uuid())
  sessionId    String      @unique
  session      TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  listeningBand Float?
  readingBand   Float?
  writingBand   Float?
  speakingBand  Float?
  overallBand   Float?
  isReleased   Boolean     @default(false)
  releasedAt   DateTime?
  createdAt    DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      NotificationType? @default(GENERIC)
  link      String?
  meta      Json?
  createdAt DateTime @default(now())
}

enum NotificationType {
  GENERIC
  LIVE_SPEAKING_REQUESTED
  LIVE_SPEAKING_SCHEDULED
  LIVE_SPEAKING_RESCHEDULED
  LIVE_SPEAKING_CANCELLED
  LIVE_SPEAKING_REMINDER
  RESULT_RELEASED
  ENROLLMENT_UPDATE
}