// ── FILE: server/src/prisma/schema.prisma ──
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(STUDENT)
  phone        String?
  avatar       String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     TestSession[]
  enrollments  Enrollment[]
  notifications Notification[]
  refreshTokens RefreshToken[]
}

enum Role {
  STUDENT
  ADMIN
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Test {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        TestType  @default(FULL)
  isPublished Boolean   @default(false)
  duration    Int       @default(165)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  modules     Module[]
  enrollments Enrollment[]
  sessions    TestSession[]
}

enum TestType {
  FULL
  LISTENING_ONLY
  READING_ONLY
  WRITING_ONLY
  SPEAKING_ONLY
}

model Module {
  id                  String      @id @default(uuid())
  testId              String
  test                Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  type                ModuleType
  title               String
  instructions        String?
  durationMins        Int
  orderIndex          Int
  audioUrl            String?
  cloudinaryPublicId  String?
  questions           Question[]
  mediaFiles          MediaFile[]
  sessions            ModuleSession[]
}

enum ModuleType {
  LISTENING
  READING
  WRITING
  SPEAKING
}

model Question {
  id             String        @id @default(uuid())
  moduleId       String
  module         Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type           QuestionType
  questionText   String
  instructions   String?
  imageUrl       String?
  imagePublicId  String?
  options        Json?
  correctAnswer  Json?
  acceptedAnswers Json?
  marks          Int           @default(1)
  orderIndex     Int
  section        Int           @default(1)
  answers        Answer[]
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE_NG
  FILL_BLANK
  SHORT_ANSWER
  MATCHING
  MATCHING_HEADINGS
  SENTENCE_COMPLETION
  DIAGRAM_LABELING
  WRITING_TASK1
  WRITING_TASK2
  SPEAKING_PART1
  SPEAKING_PART2
  SPEAKING_PART3
}

model MediaFile {
  id         String   @id @default(uuid())
  moduleId   String
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileType   FileType
  purpose    String?
  orderIndex Int     @default(0)
  createdAt  DateTime @default(now())
}

enum FileType {
  AUDIO
  IMAGE
  PDF
}

model Enrollment {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId     String
  test       Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  assignedAt DateTime  @default(now())
  dueDate    DateTime?
  assignedBy String
}

model TestSession {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId         String
  test           Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  mode           SessionMode     @default(EXAM)
  status         SessionStatus   @default(IN_PROGRESS)
  currentModule  Int             @default(0)
  startedAt      DateTime        @default(now())
  submittedAt    DateTime?
  tabSwitchCount Int             @default(0)
  modulesSessions ModuleSession[]
  result         Result?
}

enum SessionMode {
  EXAM
  PRACTICE
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  EVALUATED
  ABANDONED
}

model ModuleSession {
  id                 String               @id @default(uuid())
  sessionId          String
  session            TestSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moduleId           String
  module             Module               @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status             ModuleSessionStatus  @default(NOT_STARTED)
  startedAt          DateTime?
  submittedAt        DateTime?
  timeLeft           Int?
  answers            Answer[]
  writingSubmissions WritingSubmission[]
  speakingSubmission SpeakingSubmission?
}

enum ModuleSessionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
}

model Answer {
  id              String        @id @default(uuid())
  moduleSessionId String
  moduleSession   ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswer   String?
  isCorrect       Boolean?
  marksAwarded    Int           @default(0)
  isFlagged       Boolean       @default(false)
  savedAt         DateTime      @default(now())
}

model WritingSubmission {
  id                  String        @id @default(uuid())
  moduleSessionId     String
  moduleSession       ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  taskNumber          Int
  content             String        @db.Text
  wordCount           Int
  taskAchievement     Float?
  coherenceCohesion   Float?
  lexicalResource     Float?
  grammaticalRange    Float?
  bandScore           Float?
  feedback            String?       @db.Text
  evaluatedBy         String?
  evaluatedAt         DateTime?
}

model SpeakingSubmission {
  id                 String        @id @default(uuid())
  moduleSessionId    String        @unique
  moduleSession      ModuleSession @relation(fields: [moduleSessionId], references: [id], onDelete: Cascade)
  audioUrl           String
  audioPublicId      String?
  duration           Int?
  fluencyCoherence   Float?
  lexicalResource    Float?
  grammaticalRange  Float?
  pronunciation      Float?
  bandScore          Float?
  feedback           String?       @db.Text
  evaluatedBy        String?
  evaluatedAt        DateTime?
}

model Result {
  id           String      @id @default(uuid())
  sessionId    String      @unique
  session      TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  listeningBand Float?
  readingBand   Float?
  writingBand   Float?
  speakingBand  Float?
  overallBand   Float?
  isReleased   Boolean     @default(false)
  releasedAt   DateTime?
  createdAt    DateTime    @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}